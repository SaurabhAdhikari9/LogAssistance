@code {
    private string CurrentInput { get; set; } = string.Empty;
    private bool IsProcessing { get; set; } = false;
    private List<ChatMessage> ChatMessages { get; set; } = new();
    private string AssistantName;
    private ElementReference inputElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ScrollToBottom();
            await FocusInput();
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(CurrentInput) && !IsProcessing)
        {
            await SendMessageAsync();
        }
    }

    private void SetInput(string text)
    {
        CurrentInput = text;
    }

    private void ClearChat()
    {
        ChatMessages.Clear();
        StateHasChanged();
    }

    private async Task FocusInput()
    {
        try
        {
            await inputElement.FocusAsync();
        }
        catch { }
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        }
        catch { }
    }

    private string FormatAiResponse(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        
        var html = Markdown.ToHtml(content);
        
        // C# Post-processing helper to render glowing badges for standard Log Levels in markdown tables
        html = html.Replace("<td>Error</td>", "<td><span class=\"log-badge badge-error\">Error</span></td>")
                   .Replace("<td>ERR</td>", "<td><span class=\"log-badge badge-error\">ERR</span></td>")
                   .Replace("<td>ERROR</td>", "<td><span class=\"log-badge badge-error\">ERROR</span></td>")
                   
                   .Replace("<td>Warning</td>", "<td><span class=\"log-badge badge-warning\">Warning</span></td>")
                   .Replace("<td>WARN</td>", "<td><span class=\"log-badge badge-warning\">WARN</span></td>")
                   .Replace("<td>WARNING</td>", "<td><span class=\"log-badge badge-warning\">WARNING</span></td>")
                   
                   .Replace("<td>Information</td>", "<td><span class=\"log-badge badge-info\">Information</span></td>")
                   .Replace("<td>INFO</td>", "<td><span class=\"log-badge badge-info\">INFO</span></td>")
                   .Replace("<td>INF</td>", "<td><span class=\"log-badge badge-info\">INF</span></td>")
                   .Replace("<td>INFORMATION</td>", "<td><span class=\"log-badge badge-info\">INFORMATION</span></td>")
                   
                   .Replace("<td>Debug</td>", "<td><span class=\"log-badge badge-debug\">Debug</span></td>")
                   .Replace("<td>DBG</td>", "<td><span class=\"log-badge badge-debug\">DBG</span></td>")
                   .Replace("<td>DEBUG</td>", "<td><span class=\"log-badge badge-debug\">DEBUG</span></td>")
                   
                   .Replace("<td>Verbose</td>", "<td><span class=\"log-badge badge-verbose\">Verbose</span></td>")
                   .Replace("<td>VRB</td>", "<td><span class=\"log-badge badge-verbose\">VRB</span></td>")
                   .Replace("<td>VERBOSE</td>", "<td><span class=\"log-badge badge-verbose\">VERBOSE</span></td>")
                   
                   .Replace("<td>Fatal</td>", "<td><span class=\"log-badge badge-fatal\">Fatal</span></td>")
                   .Replace("<td>FTL</td>", "<td><span class=\"log-badge badge-fatal\">FTL</span></td>")
                   .Replace("<td>FATAL</td>", "<td><span class=\"log-badge badge-fatal\">FATAL</span></td>");

        return html;
    }

    private async Task SendMessageAsync()
    {
        var userText = CurrentInput.Trim();
        ChatMessages.Add(new ChatMessage { Role = "User", Content = userText });
        CurrentInput = string.Empty; 
        IsProcessing = true;
        
        StateHasChanged();
        await ScrollToBottom();
        await FocusInput();

        var requestPayload = new OllamaRequestDto(userText);
        AssistantName = requestPayload.AssistantName;
        
        var aiText = await assistanceService.SendMessageAsync(requestPayload);
        
        ChatMessages.Add(new ChatMessage { Role = "AI", Content = aiText });
        IsProcessing = false;
        
        StateHasChanged();
        await ScrollToBottom();
        await FocusInput();
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", @"
                setTimeout(function() {
                    var objDiv = document.getElementById('chatHistoryScroll');
                    if (objDiv) {
                        objDiv.scrollTo({
                            top: objDiv.scrollHeight,
                            behavior: 'smooth'
                        });
                    }
                }, 100);
            ");
        }
        catch { /* Ignore errors during prerendering */ }
    }
}