@page "/counter"
@rendermode InteractiveServer
@inject ILogger<Counter> _logger

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        try
        {
            int incremented = currentCount + 1;
            _logger.LogInformation($"Increment called and incremented from {currentCount} to {incremented}", currentCount, incremented);
            currentCount++;
            throw new Exception($"Invalid user id: {currentCount}");
        }
        catch (Exception e)
        {
            _logger.LogError(e.Message);
        }
    }

}