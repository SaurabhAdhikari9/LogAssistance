{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Properties": {
      "Application": "LogAssistance"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.json",
          "rollingInterval": "Day",
          "formatter": "LogAssistance.WebApp.SerilogSettings.CustomJsonFormat, LogAssistance.WebApp",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ]
  },
  "AIAssistnace": {
    "OllamaBaseUrl": "http://localhost:11434/"
  }
}
